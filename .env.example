# Generado automáticamente por `npx convex dev` en .env.local (no se commitea).
# Cópialo aquí solo como referencia de qué variables necesita el proyecto.
NEXT_PUBLIC_CONVEX_URL=

# Solo para el entorno de Railway (no en local): deploy key del deployment de
# PRODUCCIÓN de Convex. Se genera desde el dashboard de Convex → el proyecto →
# deployment de producción → Settings → Deploy Keys. `railway.json` lo usa
# para que `npx convex deploy` publique las funciones sin login interactivo y
# calcule NEXT_PUBLIC_CONVEX_URL automáticamente en cada build — no hace falta
# fijar NEXT_PUBLIC_CONVEX_URL a mano en Railway, el build lo genera solo.
CONVEX_DEPLOY_KEY=
